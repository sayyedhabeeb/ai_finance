# =============================================================================
# AI Financial Brain - Environment Variables
# Copy this file to .env and fill in real values
# =============================================================================

# ---- Application ----
APP_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# ---- Backend ----
BACKEND_PORT=8000
APP_WORKERS=4

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ---- PostgreSQL / TimescaleDB ----
POSTGRES_PORT=5432
POSTGRES_PASSWORD=changeme_secure_password

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ---- Weaviate ----
WEAVIATE_PORT=8080

# ---- MLflow ----
MLFLOW_PORT=5000

# ---- Prefect ----
PREFECT_PORT=4200

# ---- Prometheus ----
PROMETHEUS_PORT=9090

# ---- Grafana ----
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# ---- MinIO (S3-compatible storage for MLflow artifacts) ----
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ---- Authentication ----
JWT_SECRET_KEY=change_me_to_a_random_64_char_string_at_minimum_for_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ---- LLM API Keys ----
LLM_PROVIDER=groq
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama3-70b-8192
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ---- Financial Data API Keys ----
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
POLYGON_API_KEY=your_polygon_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
FRED_API_KEY=your_fred_api_key_here

# ---- Sentinel (Optional - for model monitoring) ----
SENTINEL_API_KEY=your_sentinel_api_key_here

# ---- Logging ----
LOKI_URL=http://loki:3100

# ---- Tracing (Optional) ----
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ---- Docker Registry ----
DOCKER_REGISTRY=ghcr.io
DOCKER_REGISTRY_USERNAME=your-github-username
DOCKER_REGISTRY_PASSWORD=your-github-pat

# ---- Kubernetes ----
K8S_NAMESPACE=ai-financial-brain
K8S_IMAGE_PULL_SECRET=regcred
